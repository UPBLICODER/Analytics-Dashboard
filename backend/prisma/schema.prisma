generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "sqlite"
 url      = "file:./dev.db"
}

model User {
 id       Int      @id @default(autoincrement())
 username String   @unique
 password String
 age      Int
 gender   String
 clicks   FeatureClick[]
}

model FeatureClick {
 id           Int      @id @default(autoincrement())
 user_id      Int
 feature_name String
 timestamp    DateTime @default(now())

 user User @relation(fields: [user_id], references: [id])
}